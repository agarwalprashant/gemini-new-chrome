{
  "manifest_version": 3,
  "name": "Gemini Chat: Live Assistant for Web Browsing",
  "version": "0.1.0",
  "description": "Voice-powered AI assistant with screen sharing. Talk to Google's Gemini AI and share your screen for real-time visual assistance.",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "sidePanel",
    "tabCapture",
    "desktopCapture",
    "storage"
  ],

  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "action": {
    "default_title": "Open Assistant Side Panel"
  },
  "icons": {
    "16": "icons/bot.png",
    "48": "icons/bot.png",
    "128": "icons/bot.png"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["permission.html", "permission.js", "audio-processor.js"],
      "matches": ["*://*/*"]
    }
  ],
  "minimum_chrome_version": "114"
} 